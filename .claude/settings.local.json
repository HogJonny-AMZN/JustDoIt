{
  "permissions": {
    "allow": [
      "Bash(python skills/ascii_art_generator/main.py --text=Hello --output=/tmp/justdoit_test.txt)",
      "Read(//tmp/**)",
      "Bash(python3 skills/ascii_art_generator/main.py --text=Hello --output=/tmp/justdoit_test.txt)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(.venv/bin/pytest:*)",
      "Bash(.venv/bin/python:*)",
      "Bash(scripts/generate_gallery.py:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-test.sh \"$CLAUDE_TOOL_INPUT_PATH\""
          }
        ]
      }
    ]
  }
}
