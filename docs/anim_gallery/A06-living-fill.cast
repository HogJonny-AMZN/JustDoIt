[23.9,"o","\u001b[2J\u001b[H\u001b[1m\u001b[92m\u00b7\u2593\u2588\u2593\u2591\u2591 \u2592\u2591  \u2591\u2592  \u2591\u2593\u2591\u2591\u2592 \u00b7\u2591\u2592\u2591\u2591\u2593     \u00b7\u00b7\u00b7\u00b7\u00b7   \u2591\u2593\u2593\u2591      \u2591\u2592\u2592\u00b7\u00b7\u2591 \u2591\u2592\u2591\u00b7\u2591\u00b7 \u001b[0m\n\u001b[1m\u001b[92m   \u2588\u2591  \u2591\u2591  \u2591\u2591 \u2593\u2593       \u2591\u2593       \u2591\u2591  \u2592\u2591 \u2591\u2593  \u2591\u2591       \u2591\u00b7     \u2591\u2593   \u001b[0m\n\u001b[1m\u001b[92m   \u2593\u2591  \u2591\u2592  \u2592\u2591 \u2588\u2591       \u00b7\u2591       \u2593\u2591  \u2591\u2588 \u2591\u2593  \u2591\u2591       \u00b7\u2591     \u2593\u2593   \u001b[0m\n\u001b[1m\u001b[92m   \u2591\u2591  \u2591\u2591  \u2592\u2591  \u2592\u2591\u2591\u2593    \u00b7\u00b7       \u2588\u2591  \u2593\u2591 \u2593\u2591  \u2593\u2591       \u2592\u2591     \u2591\u2593   \u001b[0m\n\u001b[1m\u001b[92m\u2593\u2593 \u2591\u2591  \u2592\u00b7  \u2591\u2591     \u2593\u2593   \u2591\u2591       \u2591\u2593  \u2591\u2588 \u2591\u2591  \u2591\u2591       \u00b7\u2591     \u00b7\u00b7   \u001b[0m\n\u001b[1m\u001b[92m \u2591\u2591\u2591\u2592   \u00b7\u00b7\u2591\u2592  \u2591\u00b7\u2592\u2591\u2591    \u2593\u2591       \u2591\u2593\u2591\u2593\u2591   \u2591\u2591\u2591\u2591      \u2591\u2591\u2591\u00b7\u2591\u2593   \u00b7\u00b7   \u001b[0m\n\u001b[1m\u001b[92m                                                                \u001b[0m"]
